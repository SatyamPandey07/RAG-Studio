# RAG Studio — Environment Configuration
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────
# Demo Mode (set to false to use real API calls)
# ─────────────────────────────────────────────
DEMO_MODE=true

# ─────────────────────────────────────────────
# API Keys (optional in demo mode)
# ─────────────────────────────────────────────

# Google Gemini API Key (free tier available at https://aistudio.google.com)
# Used for: text-embedding-004 embeddings + Gemini 2.0 Flash chat
GOOGLE_API_KEY=

# OpenAI API Key (optional)
OPENAI_API_KEY=

# Anthropic API Key (optional)
ANTHROPIC_API_KEY=

# Cohere API Key (optional — for real reranking)
COHERE_API_KEY=

# ─────────────────────────────────────────────
# Database (SQLite by default — no setup required)
# ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./rag_studio.db

# ─────────────────────────────────────────────
# Vector Store (in-memory Qdrant by default)
# Set QDRANT_HOST to use a remote/Docker Qdrant instance
# ─────────────────────────────────────────────
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# ─────────────────────────────────────────────
# File Upload
# ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
